###############################################################
# EC2 — BASTION HOST
# Public jump instance — hardened and auditable
###############################################################

resource "aws_instance" "bastion" {
  ami                         = data.aws_ami.amazon_linux_2023.id
  instance_type               = var.bastion_instance_type
  subnet_id                   = aws_subnet.public[0].id
  vpc_security_group_ids      = [aws_security_group.bastion.id]
  key_name                    = aws_key_pair.bastion.key_name
  associate_public_ip_address = true

  # Security: instance metadata requires IMDSv2 (prevents SSRF attacks)
  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required" # IMDSv2 enforced
    http_put_response_hop_limit = 1
  }

  # Encrypted root volume
  root_block_device {
    volume_type           = "gp3"
    volume_size           = 20
    encrypted             = true
    delete_on_termination = true

    tags = {
      Name = "${local.name_prefix}-bastion-root"
    }
  }

  # User data: initial OS hardening
  user_data = base64encode(templatefile("${path.module}/templates/bastion_userdata.sh.tpl", {
    environment  = var.environment
    project_name = var.project_name
  }))

  # IAM Role for SSM Session Manager (safer alternative to SSH in production)
  iam_instance_profile = aws_iam_instance_profile.bastion.name

  tags = {
    Name = "${local.name_prefix}-bastion"
    Role = "bastion"
  }

  # Prevent accidental termination
  lifecycle {
    ignore_changes = [ami] # Do not recreate if AMI updates automatically
  }
}

# EIP — fixed IP for the bastion (required for firewall whitelisting)
resource "aws_eip" "bastion" {
  instance = aws_instance.bastion.id
  domain   = "vpc"

  tags = {
    Name = "${local.name_prefix}-bastion-eip"
  }

  depends_on = [aws_internet_gateway.main]
}

###############################################################
# EC2 — PRIVATE INSTANCE (workload example)
###############################################################

resource "aws_instance" "private_app" {
  ami                         = data.aws_ami.amazon_linux_2023.id
  instance_type               = var.app_instance_type
  subnet_id                   = aws_subnet.private[0].id
  vpc_security_group_ids      = [aws_security_group.private_instances.id]
  key_name                    = aws_key_pair.bastion.key_name
  associate_public_ip_address = false # No public IP — fully isolated from the internet

  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required" # IMDSv2 enforced
    http_put_response_hop_limit = 1
  }

  root_block_device {
    volume_type           = "gp3"
    volume_size           = 20
    encrypted             = true
    delete_on_termination = true

    tags = {
      Name = "${local.name_prefix}-app-root"
    }
  }

  iam_instance_profile = aws_iam_instance_profile.private_app.name

  tags = {
    Name = "${local.name_prefix}-private-app"
    Role = "application"
  }
}

###############################################################
# KEY PAIR
# Generated by Terraform, private key saved locally
###############################################################

resource "tls_private_key" "bastion" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

resource "aws_key_pair" "bastion" {
  key_name   = "${local.name_prefix}-bastion-key"
  public_key = tls_private_key.bastion.public_key_openssh

  tags = {
    Name = "${local.name_prefix}-bastion-key"
  }
}

# Save private key locally with correct permissions
resource "local_sensitive_file" "bastion_private_key" {
  content         = tls_private_key.bastion.private_key_pem
  filename        = "${path.root}/../keys/${local.name_prefix}-bastion.pem"
  file_permission = "0600" # Correct permission for SSH
}
