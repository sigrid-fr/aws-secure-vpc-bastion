# ── Terraform ────────────────────────────────────────────
# Local .terraform directories (provider cache, modules)
**/.terraform/*

# State files — NEVER commit (contain sensitive infra data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files — likely contain secrets (passwords, keys, tokens)
*.tfvars
*.tfvars.json

# Override files (used for local overrides only)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan output files
*.tfplan

# CLI configuration files
.terraformrc
terraform.rc

# Backup files generated by Terraform
*.backup
*.bak

# ── SSH Keys — NEVER commit ──────────────────────────────
keys/
*.pem
*.key

# ── Python ───────────────────────────────────────────────
__pycache__/
*.pyc
.pytest_cache/
.venv/

# Test reports (generated artifacts)
reports/

# ── OS & IDE ─────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
*.swp
*.tmp
